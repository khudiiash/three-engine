{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Three Engine",
  "version": "0.1.0",
  "identifier": "com.khudiiash.threeengine",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Three Engine",
        "width": 1600,
        "height": 950,
        "minWidth": 1100,
        "minHeight": 650,
        "center": true,
        "additionalBrowserArgs": "--enable-unsafe-webgpu"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
